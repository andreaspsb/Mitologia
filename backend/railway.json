{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/backend/Dockerfile",
    "watchPatterns": [
      "/backend/**",
      "/alembic/**",
      "/scripts/**",
      "/pyproject.toml",
      "/alembic.ini"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  }
}
